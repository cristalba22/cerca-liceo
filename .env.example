# Copiar este archivo como .env.local y pegar los datos del proyecto Supabase.
# Mientras queden vacios, la app funciona en modo demo local con localStorage.

VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=TU_ANON_KEY_PUBLICA

# Si Supabase te muestra la key moderna como publishable, tambien sirve:
# VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
